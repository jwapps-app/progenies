# PostgreSQL
POSTGRES_USER=kindred
POSTGRES_PASSWORD=kindred
POSTGRES_DB=genealogy

# Branding (provisional working title — change both to rebrand the app)
APP_NAME=Progenies
VITE_APP_NAME=Progenies

# Backend
DATABASE_URL=postgresql://kindred:kindred@db:5432/genealogy
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
BCRYPT_ROUNDS=12
CORS_ORIGINS=http://localhost:5173
# Extra allowed-origin regex (on top of CORS_ORIGINS). Secure default: empty; dev
# compose opts into a localhost/private-LAN regex for phone/iPad testing.
CORS_ORIGIN_REGEX=
# Refresh-cookie Secure flag. Secure default: true (cookie sent over HTTPS only);
# dev compose opts out because dev runs on plain http.
COOKIE_SECURE=true
# Interactive API docs (/docs, /redoc, /openapi.json). Secure default: false so
# prod doesn't expose its schema; dev compose opts in.
DOCS_ENABLED=false

# Frontend
# Leave blank to auto-detect the API from the page's host (works at localhost,
# 127.0.0.1, and the machine's LAN IP). Set only if the API lives on a different
# host/domain, e.g. behind the Cloudflare Tunnel in production.
VITE_API_BASE_URL=
